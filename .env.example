# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# WalletConnect - Get from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# Polymarket Builder API - Get from Polymarket Builder Grant
POLY_BUILDER_API_KEY="your-polymarket-builder-api-key"
NEXT_PUBLIC_POLY_BUILDER_KEY="your-polymarket-builder-api-key"

# Polygon RPC - Get from https://alchemy.com/
POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/your-api-key"
NEXT_PUBLIC_POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/your-api-key"

# SabiMarket Builder Wallet (receives builder fees from Polymarket)
BUILDER_WALLET_ADDRESS="0xYourBuilderWalletAddress"
NEXT_PUBLIC_BUILDER_WALLET_ADDRESS="0xYourBuilderWalletAddress"

# Site URL
NEXT_PUBLIC_SITE_URL="https://sabimarket.xyz"

# Sentry (optional) - Get from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
